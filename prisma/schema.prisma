// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ParticipationType {
  INDIVIDUAL
  TEAM
}

enum ExperienceLevel {
  BEGINNER // 비개발자/입문
  JUNIOR // 주니어
  SENIOR // 시니어
  VIBE_CODER // 바이브코더
}

enum TeamStatus {
  PENDING // 대기 (입금 확인 전 기본값)
  CONFIRMED // 확정 (입금 확인 + 참가 확정)
  WAITLISTED // 예비 (정원 초과 대기)
  REFUNDED // 환불 (환불 처리 완료)
}

model Team {
  id String @id @default(cuid())

  // 참가 유형
  participationType ParticipationType @default(INDIVIDUAL) @map("participation_type")

  // 팀 정보 (팀 참여 시)
  teamName String? @map("team_name") // 팀 이름

  // 상태 관리
  status          TeamStatus @default(PENDING)
  recruiting      Boolean    @default(false) // 팀원 모집 중 여부
  recruitmentNote String?    @map("recruitment_note") // 팀 주제

  // 추가 정보
  experienceLevel ExperienceLevel @default(BEGINNER) @map("experience_level")
  motivation      String? // 참가 동기

  // 환불 계좌 정보
  refundBank          String @map("refund_bank") // 은행명
  refundAccount       String @map("refund_account") // 계좌번호
  refundAccountHolder String @map("refund_account_holder") // 예금주

  hasDeposited     Boolean @default(false) @map("has_deposited") // 신청자 자가 입금 여부
  depositConfirmed Boolean @default(false) @map("deposit_confirmed") // 관리자 입금 확인

  privacyConsent Boolean   @default(false) @map("privacy_consent") // 개인정보 수집·이용 동의
  consentedAt    DateTime? @map("consented_at") // 동의 일시

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members  Member[]
  projects Project[]

  @@map("teams")
}

model Member {
  id     String @id @default(cuid())
  teamId String @map("team_id")
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  name     String
  email    String  @unique // 투표 인증용
  phone    String // 연락처
  isLeader    Boolean @default(false) @map("is_leader")
  seekingTeam Boolean @default(false) @map("seeking_team") // 팀 구하는 중 여부

  // 환불 계좌 정보 (멤버 개인)
  refundBank          String? @map("refund_bank")
  refundAccount       String? @map("refund_account")
  refundAccountHolder String? @map("refund_account_holder")

  // 관리자 메모
  adminNote String? @map("admin_note")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  votes Vote[]
  likes Like[]

  @@map("members")
}

model Project {
  id     String @id @default(cuid())
  teamId String @map("team_id")
  team   Team   @relation(fields: [teamId], references: [id])

  title       String
  description String?

  features String? @map("features")
  tools    String? @map("tools")

  githubUrl String? @map("github_url")
  demoUrl   String? @map("demo_url")
  videoUrl  String? @map("video_url")
  imageUrl  String? @map("image_url")
  linkUrl   String? @map("link_url")

  promptResult   String? @map("prompt_result") @db.Text
  promptFeedback String? @map("prompt_feedback") @db.Text
  promptScore    Int?    @map("prompt_score")
  catFeedback    String? @map("cat_feedback") @db.Text
  catScore       Int?    @map("cat_score")

  isFinals  Boolean @default(false) @map("is_finals")
  adminMemo String? @map("admin_memo") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  votes         Vote[]
  likes         Like[]
  eventSettings EventSetting[]

  @@map("projects")
}

model Vote {
  id       String @id @default(cuid())
  memberId String @map("member_id")
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([memberId, projectId])
  @@map("votes")
}

model RegistrationSetting {
  id       String  @id @default(cuid())
  isClosed Boolean @default(false) @map("is_closed")

  closedAt  DateTime? @map("closed_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("registration_settings")
}

model Like {
  id       String @id @default(cuid())
  memberId String @map("member_id")
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([memberId, projectId])
  @@map("likes")
}

model EventSetting {
  id       String @id @default(cuid())
  maxVotes Int    @default(5) @map("max_votes")

  presentingProjectId String?  @map("presenting_project_id")
  presentingProject   Project? @relation(fields: [presentingProjectId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("event_settings")
}

model ArchivedProject {
  id String @id @default(cuid())

  // 프로젝트 정보
  title       String
  description String?
  features    String?
  tools       String?
  githubUrl   String? @map("github_url")
  demoUrl     String? @map("demo_url")
  videoUrl    String? @map("video_url")
  imageUrl    String? @map("image_url")
  linkUrl     String? @map("link_url")

  // 심사 결과
  promptFeedback String? @map("prompt_feedback") @db.Text
  promptScore    Int?    @map("prompt_score")
  catFeedback    String? @map("cat_feedback") @db.Text
  catScore       Int?    @map("cat_score")

  // 카운트
  voteCount Int @default(0) @map("vote_count") // 0이면 미사용, 화면에서 미노출
  likeCount Int @default(0) @map("like_count")

  // 팀 정보 스냅샷
  teamName        String? @map("team_name")
  motivation      String?
  recruitmentNote String? @map("recruitment_note")
  experienceLevel String? @map("experience_level")

  // 멤버 스냅샷
  members Json? // 이메일과 이름만 유지, 전화번호, 계좌번호 제거

  // 원본 참조
  originalProjectId String? @unique @map("original_project_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("archived_projects")
}
